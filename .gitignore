# Trinit monorepo root .gitignore
# NOTE: trinit-vscode/ is a separate git repository (Zoo Code fork) with its
# own .gitignore. Do NOT add rules here that are only meant for its internals
# (e.g. .roo/, webview-ui build output, etc.) — manage those in
# trinit-vscode/.gitignore instead.

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Packaged extension artifacts
*.vsix

# Turborepo cache
.turbo/

# Environment files
.env
.env.*
!.env.example
!.env.*.sample

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/

# VS Code extension test runner artifacts
.vscode-test/

# OS files
.DS_Store
.AppleDouble
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
.cache/

# Local research docs (not for version control)
dev/
